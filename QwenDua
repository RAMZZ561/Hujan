-- ============================================
-- UTILITY FUNCTIONS
-- ============================================
local function Create(class, properties, children)
    local obj = Instance.new(class)
    for prop, value in pairs(properties or {}) do
        obj[prop] = value
    end
    for _, child in pairs(children or {}) do
        child.Parent = obj
    end
    return obj
end

local function AddCorner(parent, radius)
    local corner = Create("UICorner", {
        CornerRadius = UDim.new(0, radius or 8),
        Parent = parent
    })
    return corner
end

local function AddStroke(parent, color, thickness)
    local stroke = Create("UIStroke", {
        Color = color or Theme.Border,
        Thickness = thickness or 1,
        Parent = parent
    })
    return stroke
end

local function AddPadding(parent, padding)
    local pad = Create("UIPadding", {
        PaddingTop = UDim.new(0, padding or 10),
        PaddingBottom = UDim.new(0, padding or 10),
        PaddingLeft = UDim.new(0, padding or 10),
        PaddingRight = UDim.new(0, padding or 10),
        Parent = parent
    })
    return pad
end

local function Tween(obj, props, time, style)
    local tween = TweenService:Create(obj, TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
    tween:Play()
    return tween
end

local function RippleEffect(button, color)
    button.MouseButton1Click:Connect(function()
        local ripple = Create("Frame", {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = color or Theme.Accent,
            BackgroundTransparency = 0.7,
            ZIndex = 100,
            Parent = button
        })
        AddCorner(ripple, 999)
        Tween(ripple, {Size = UDim2.new(1, 50, 1, 50)}, 0.4)
        Tween(ripple, {BackgroundTransparency = 1}, 0.4)
        task.delay(0.4, function()
            ripple:Destroy()
        end)
    end)
end

