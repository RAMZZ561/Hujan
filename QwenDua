        if ESPObjects[player].SkeletonGui then ESPObjects[player].SkeletonGui:Destroy() end
        ESPObjects[player] = nil
    end
end

local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")
            local head = character:FindFirstChild("Head")

            if humanoid and hrp and head and humanoid.Health > 0 then
                if Config.ESP.TeamCheck and player.Team == LocalPlayer.Team then
                    if ESPObjects[player] then RemoveESPForPlayer(player) end
                    continue
                end

                local distance = (hrp.Position - (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.zero)).Magnitude
                if distance > Config.ESP.MaxDistance then
                    if ESPObjects[player] then RemoveESPForPlayer(player) end
                    continue
                end

                if not ESPObjects[player] then
                    CreateESPForPlayer(player)
                end

                local esp = ESPObjects[player]
                if not esp then continue end

                local isVisible = Config.ESP.Enabled

                if esp.BillboardGui then
                    esp.BillboardGui.Adornee = hrp
                    esp.BillboardGui.Enabled = isVisible

                    if esp.Box then
                        esp.Box.Visible = isVisible and Config.ESP.Boxes
                    end

                                    if esp.NameTag then
                    esp.NameTag.Visible = isVisible and Config.ESP.Names
                    esp.NameTag.Text = player.DisplayName or player.Name
                end

                if esp.HealthBar then
                    esp.HealthBar.Visible = isVisible and Config.ESP.Health
                    if esp.HealthFill then
                        local healthPercent = humanoid.Health / humanoid.MaxHealth
                        esp.HealthFill.Size = UDim2.new(1, 0, healthPercent, 0)
                        esp.HealthFill.BackgroundColor3 = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
                    end
                end

                if esp.DistLabel then
                    esp.DistLabel.Visible = isVisible and Config.ESP.Distance
                    esp.DistLabel.Text = string.format("%.0fm", distance)
                end
            end

            if esp.LineGui and esp.Line then
                esp.LineGui.Enabled = isVisible and Config.ESP.Lines
                if isVisible and Config.ESP.Lines then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        local startX = Camera.ViewportSize.X / 2
                        local startY = Camera.ViewportSize.Y
                        local endX = screenPos.X
                        local endY = screenPos.Y

                        local dx = endX - startX
                        local dy = endY - startY
                        local length = math.sqrt(dx * dx + dy * dy)
                        local angle = math.deg(math.atan2(dy, dx))

                        esp.Line.Position = UDim2.new(0, startX, 0, startY)
                        esp.Line.Size = UDim2.new(0, length, 0, 2)
                        esp.Line.Rotation = angle
                    end
                end
            end

            if esp.SkeletonGui then
                esp.SkeletonGui.Adornee = hrp
                esp.SkeletonGui.Enabled = isVisible and Config.ESP.Skeleton
            end
        else
            if ESPObjects[player] then RemoveESPForPlayer(player) end
        end
    else
        if ESPObjects[player] then RemoveESPForPlayer(player) end
    end
end

local function DrawSkeleton(player)
    if not ESPObjects[player] then return end
    local esp = ESPObjects[player]
    local character = player.Character
    if not character then return end

    for _, child in ipairs(esp.SkeletonGui:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    if not Config.ESP.Skeleton or not Config.ESP.Enabled then return end

    local bonePairs = {
        {"Head", "UpperTorso"},
        {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "LeftUpperArm"},
        {"UpperTorso", "RightUpperArm"},
        {"LeftUpperArm", "LeftLowerArm"},
        {"RightUpperArm", "RightLowerArm"},
        {"LowerTorso", "LeftUpperLeg"},
        {"LowerTorso", "RightUpperLeg"},
        {"LeftUpperLeg", "LeftLowerLeg"},
        {"RightUpperLeg", "RightLowerLeg"}
    }

    local skeletonColor = Color3.fromRGB(255, 200, 60)

    for _, pair in ipairs(bonePairs) do
        local part1 = character:FindFirstChild(pair[1])
        local part2 = character:FindFirstChild(pair[2])
        if part1 and part2 then
            local screen1, on1 = Camera:WorldToViewportPoint(part1.Position)
            local screen2, on2 = Camera:WorldToViewportPoint(part2.Position)
            if on1 and on2 then
                local dx = screen2.X - screen1.X
                local dy = screen2.Y - screen1.Y
                local length = math.sqrt(dx * dx + dy * dy)
                local angle = math.deg(math.atan2(dy, dx))

                local bone = Create("Frame", {
                    Size = UDim2.new(0, length, 0, 2),
                    Position = UDim2.new(0, screen1.X, 0, screen1.Y),
                    Rotation = angle,
                    BackgroundColor3 = skeletonColor,
                    BorderSizePixel = 0,
                    Parent = esp.SkeletonGui
                })
            end
        end
    end
end

