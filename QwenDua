local function CreateToggle(parent, text, default, callback, order)
    local card = CreateCard(parent, order)
    card.Size = UDim2.new(1, 0, 0, 36)

    local label = Create("TextLabel", {
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamSemibold,
        Text = text,
        TextSize = 10,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card
    })

    local toggleBg = Create("Frame", {
        Size = UDim2.new(0, 36, 0, 18),
        Position = UDim2.new(1, -48, 0.5, -9),
        BackgroundColor3 = default and Theme.Accent or Theme.ToggleOff,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        Parent = card
    })
    AddCorner(toggleBg, 999)

    local toggleCircle = Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = default and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        Parent = toggleBg
    })
    AddCorner(toggleCircle, 999)

    local btn = Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = card
    })

    local state = default or false

    btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            Tween(toggleBg, {BackgroundColor3 = Theme.Accent}, 0.3)
            Tween(toggleCircle, {Position = UDim2.new(1, -16, 0.5, -7)}, 0.3)
        else
            Tween(toggleBg, {BackgroundColor3 = Theme.ToggleOff}, 0.3)
            Tween(toggleCircle, {Position = UDim2.new(0, 2, 0.5, -7)}, 0.3)
        end
        if callback then callback(state) end
    end)

    return {
        Card = card,
        SetState = function(self, newState)
            state = newState
            if state then
                Tween(toggleBg, {BackgroundColor3 = Theme.Accent}, 0.3)
                Tween(toggleCircle, {Position = UDim2.new(1, -16, 0.5, -7)}, 0.3)
            else
                Tween(toggleBg, {BackgroundColor3 = Theme.ToggleOff}, 0.3)
                Tween(toggleCircle, {Position = UDim2.new(0, 2, 0.5, -7)}, 0.3)
            end
        end
    }
end

