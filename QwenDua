        isOpen = not isOpen
        if isOpen and not dropdownFrame then
            dropdownFrame = Create("Frame", {
                Size = UDim2.new(0.38, -20, 0, #options * 22 + 4),
                Position = UDim2.new(0.55, 0, 1, 3),
                BackgroundColor3 = Theme.Background,
                BackgroundTransparency = 0,
                BorderSizePixel = 0,
                ZIndex = 10,
                Parent = card
            })
            AddCorner(dropdownFrame, 5)
            AddStroke(dropdownFrame, Theme.Border, 1)

            for i, option in ipairs(options) do
                local optBtn = Create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 22),
                    Position = UDim2.new(0, 0, 0, (i-1) * 22),
                    BackgroundTransparency = 1,
                    Font = Enum.Font.GothamSemibold,
                    Text = option,
                    TextSize = 9,
                    TextColor3 = Theme.TextDim,
                    ZIndex = 11,
                    Parent = dropdownFrame
                })

                optBtn.MouseEnter:Connect(function()
                    Tween(optBtn, {BackgroundTransparency = 0.5, BackgroundColor3 = Theme.Tertiary}, 0.15)
                end)
                optBtn.MouseLeave:Connect(function()
                    Tween(optBtn, {BackgroundTransparency = 1}, 0.15)
                end)

                optBtn.MouseButton1Click:Connect(function()
                    selectedLabel.Text = option
                    isOpen = false
                    if dropdownFrame then dropdownFrame:Destroy() dropdownFrame = nil end
                    if callback then callback(option) end
                end)
            end
        elseif dropdownFrame then
            dropdownFrame:Destroy()
            dropdownFrame = nil
        end
    end)

    return card
end

-- ============================================
-- TAB SWITCHING
-- ============================================
function SwitchTab(tabName)
    UIState.CurrentTab = tabName

    for name, tab in pairs(Tabs) do
        if name == tabName then
            Tween(tab.Button, {BackgroundColor3 = Theme.Tertiary}, 0.3)
            Tween(tab.Icon, {TextColor3 = Theme.Accent}, 0.3)
            Tween(tab.Label, {TextColor3 = Theme.Text}, 0.3)
            tab.Indicator.Visible = true
            Tween(tab.Indicator, {Size = UDim2.new(0, 3, 0, 18)}, 0.3)
        else
            Tween(tab.Button, {BackgroundColor3 = Theme.Secondary}, 0.3)
            Tween(tab.Icon, {TextColor3 = Theme.TextDim}, 0.3)
            Tween(tab.Label, {TextColor3 = Theme.TextDim}, 0.3)
            tab.Indicator.Visible = false
        end
    end

    for name, frame in pairs(TabFrames) do
        if name == tabName then
            frame.Visible = true
            Tween(frame, {Position = UDim2.new(0, 8, 0, 8)}, 0.3)
        else
            frame.Visible = false
        end
    end
end

