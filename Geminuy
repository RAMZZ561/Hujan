-- [AIMBOT LOGIC - OPTIMIZED]
local function getClosestPlayer()
    local target, maxDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if dist < Engine.Aimbot.Fov and dist < maxDist then
                    target = p.Character.HumanoidRootPart
                    maxDist = dist
                end
            end
        end
    end
    return target
end

-- [TELEPORT UI - DYNAMIC]
local function updateTeleportList()
    -- Clear previous buttons
    for _, child in pairs(Content:GetChildren()) do if child.Name == "PlayerButton" then child:Destroy() end end
    
    for _, player in pairs(Players:GetPlayers()) do
        local btn = Instance.new("TextButton", Content)
        btn.Name = "PlayerButton"
        btn.Text = player.Name
        btn.MouseButton1Click:Connect(function()
            localPlayer.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame
        end)
    end
end

